{
  "name": "Vendor Performance Modern",
  "background": "#F4F7FB",
  "foreground": "#12344D",
  "tableAccent": "#1F7A8C",
  "dataColors": [
    "#12344D",
    "#1F7A8C",
    "#1A936F",
    "#F4B942",
    "#D95D39",
    "#5C7CFA",
    "#7D8EA3",
    "#90BE6D"
  ],
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#12344D" } },
            "alignment": "left",
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#12344D" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F4F7FB" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "calloutValue": [
          {
            "color": { "solid": { "color": "#12344D" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#5F6C7B" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": { "solid": { "color": "#12344D" } },
            "textSize": 11,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}
